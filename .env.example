# Copy to `.env.local`: `cp .env.example .env.local`

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5000

# Web push only — Firebase Console → paynexa-fc9ca → Cloud Messaging → Web Push certificates → Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# App Links / Universal Links for https://paynexa-web-workspace.vercel.app/pay/*
ANDROID_APP_PACKAGE=com.paynexa.paynexa
ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99
IOS_APP_ID=TEAMID.com.example.escrowApp
