# Copy to `.env.local`: `cp .env.example .env.local`

# Direct service URLs (no API gateway). Defaults match local Nest ports.
NEXT_PUBLIC_USER_SERVICE_URL=https://paynexa-user-service-production.up.railway.app
NEXT_PUBLIC_TRANSACTION_SERVICE_URL=https://paynexa-transaction-service-production.up.railway.app
NEXT_PUBLIC_ESCROW_SERVICE_URL=https://paynexa-escrow-service-production.up.railway.app
NEXT_PUBLIC_MESSAGING_SERVICE_URL=https://blissful-embrace-production-51c6.up.railway.app
NEXT_PUBLIC_PRODUCT_SERVICE_URL=https://paynexa-product-service-production.up.railway.app

const _defaultUserService = '';
const _defaultTransactionService = '';
const _defaultEscrowService = '';
const _defaultMessagingService = '';
const _defaultProductService = '';


# Web push only — Firebase Console → paynexa-fc9ca → Cloud Messaging → Web Push certificates → Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# App Links / Universal Links for https://paynexa-web-workspace.vercel.app/pay/*
ANDROID_APP_PACKAGE=com.paynexa.paynexa
ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99
IOS_APP_ID=TEAMID.com.example.escrowApp
